rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Insights — users can only access their own documents
    match /insights/{insightId} {

      // Transcript subcollection — same ownership as the parent insight
      match /private/{docId} {
        allow read, write: if request.auth != null
          && get(/databases/$(database)/documents/insights/$(insightId)).data.userId == request.auth.uid;
      }

      // Read: must be signed in and own the document
      allow read: if request.auth != null
                  && resource.data.userId == request.auth.uid;

      // Create: must be signed in and setting userId to their own uid
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;

      // Update: must be signed in and own the document
      allow update: if request.auth != null
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.userId == request.auth.uid;

      // Delete: must be signed in and own the document
      allow delete: if request.auth != null
                    && resource.data.userId == request.auth.uid;
    }

    // User settings — each user owns their own settings document
    match /userSettings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Public shares — anyone with the link can read; only the owner can
    // create, and only the owner can modify or delete their own shares
    match /shares/{token} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if request.auth != null
                            && resource.data.ownerId == request.auth.uid;
    }

    // Block everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
